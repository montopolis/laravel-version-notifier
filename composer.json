{
    "name": "montopolis/laravel-version-notifier",
    "description": "Version notification system for Laravel applications - detect deployments and prompt users to refresh",
    "type": "library",
    "license": "proprietary",
    "authors": [
        {
            "name": "Montopolis",
            "email": "dev@montopolis.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/broadcasting": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Montopolis\\LaravelVersionNotifier\\": "src/"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Montopolis\\LaravelVersionNotifier\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Montopolis\\LaravelVersionNotifier\\VersionNotifierServiceProvider"
            ],
            "aliases": {
                "VersionNotifier": "Montopolis\\LaravelVersionNotifier\\Facades\\VersionNotifier"
            }
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
